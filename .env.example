# Copy this file to .env for local development, and set the same two
# values in your hosting provider's environment variable settings for
# production (e.g. Vercel → Project Settings → Environment Variables).

# Safe to expose in the browser — starts with pk_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# NEVER expose this in frontend code or commit it — starts with sk_
# Only used inside /api/create-checkout-session.js on the server.
STRIPE_SECRET_KEY=sk_test_...
